CREATE DATABASE simulaatio;

CREATE TABLE Customer (
   customer_id INT AUTO_INCREMENT NOT NULL,
   arrival_time TIME NOT NULL,
   ticket_type ENUM('VIP','GA') NOT NULL,
   quantity_of_clothes_etc INT NOT NULL,
   security_time INT NOT NULL,
   cloakroom BOOLEAN NOT NULL,
   cloakroom_time INT NULL,
   merch BOOLEAN NOT NULL,
   merch_time INT NULL,
   enter_concert_hall_time TIME NOT NULL,
   PRIMARY KEY(customer_id)
);

CREATE USER 'konsertti'@'localhost' IDENTIFIED BY 'simulaatio';
GRANT SELECT, INSERT, UPDATE, DELETE ON simulaatio.* TO 'konsertti'@'localhost';

